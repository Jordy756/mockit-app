---
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"button"> {
  variant?: "primary" | "secondary" | "text";
}

const { variant = "primary", class: className, ...rest } = Astro.props;
---

<button
  class:list={[
    "flex items-center justify-center gap-3 font-medium cursor-pointer whitespace-nowrap transition-opacity rounded-sm hover:opacity-80 disabled:cursor-not-allowed disabled:opacity-50",
    `btn-${variant}`,
    className,
  ]}
  {...rest}
>
  <slot />
</button>
