---
import GenerateIcon from "@components/icons/Generate.astro";
import Button from "@components/ui/Button.astro";

const initialJson = `{
  "name": "Nombre de una persona",
  "email": "Correo electrónico de prueba",
  "linkedIn": "Perfil de LinkedIn de prueba"
}`;
---

<section
  class="relative flex-1 md:flex-[1.5] lg:flex-[2.5] bg-neutral-900 min-h-100 border border-neutral-800 overflow-hidden rounded-md"
>
  <div class="text-sm">
    <textarea
      id="json-textarea"
      spellcheck="false"
      class="absolute inset-0 p-4 resize-none bg-transparent text-transparent caret-neutral-50 outline-none z-10 font-mono"
      >{initialJson}</textarea
    >
    <pre
      id="json-display"
      aria-hidden="true"
      class="absolute inset-0 p-4 overflow-auto pointer-events-none whitespace-pre-wrap break-all text-neutral-50 font-mono">
    </pre>
  </div>
  <footer class="absolute bottom-0 right-0 p-4 flex items-center flex-wrap gap-4 z-20">
    <Button id="format-and-erase-btn" variant="secondary" class="flex-1 bg-neutral-900">Organizar</Button>
    <Button id="generate-mocks-btn" class="flex-1">
      Generar Datos
      <GenerateIcon class="w-5 h-5" />
    </Button>
  </footer>
</section>
