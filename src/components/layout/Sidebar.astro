---
import CodeIcon from "@components/icons/Code.astro";
import GithubIcon from "@components/icons/Github.astro";
---

<aside class="relative bg-neutral-900 col-start-1 row-span-3">
  <nav class="sticky top-0 left-0 flex flex-col justify-between gap-8 p-4 h-screen">
    <ul class="flex flex-col items-center gap-4">
      <li>
        <a href="/#">
          <CodeIcon class="w-8 h-8" />
        </a>
      </li>
    </ul>
    <ul class="flex flex-col gap-4">
      <li>
        <a href="https://github.com/Jordy756/mockit" target="_blank" rel="noopener noreferrer">
          <GithubIcon class="w-8 h-8" />
        </a>
      </li>
    </ul>
  </nav>
</aside>
